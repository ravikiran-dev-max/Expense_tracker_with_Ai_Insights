# Server Configuration
PORT=5000
NODE_ENV=development

# Database Settings (MongoDB Local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/expense-tracker

# Authentication (JWT Secret Key - 32+ characters recommended)
JWT_SECRET=YOUR_SUPER_SECRET_JWT_SIGNING_KEY_32_CHARS

# AI Service Provider Selection ('gemini' or 'ollama')
AI_PROVIDER=gemini

# Google Gemini API Settings (Required if AI_PROVIDER=gemini)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Ollama Settings (Required if AI_PROVIDER=ollama)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Cloudinary Credentials (Optional for cloud-hosted avatar uploads)
# If provided, avatar uploads will be stored on Cloudinary instead of local disk storage.
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
